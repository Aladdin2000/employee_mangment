@model employees_mangment.Models.PropertyDefinition

@{
    ViewBag.Title = "Edit Property";
}

<div style="padding: 30px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh;">
    <div style="background: white; border-radius: 15px; padding: 40px; width: 100%; box-shadow: 0 10px 30px rgba(0,0,0,0.2);">

        <h2 style="font-size: 28px; font-weight: bold; margin-bottom: 30px; color: #333; border-bottom: 3px solid #667eea; padding-bottom: 10px;">
             Edit Property
        </h2>

        <form action="/PropertyDefinition/Edit/@Model.Id" method="post">
            @Html.AntiForgeryToken()

            <div style="margin-bottom: 25px;">
                <label style="font-size: 20px; font-weight: bold; display: block; margin-bottom: 8px; color: #555;">Property Name</label>
                @Html.TextBoxFor(m => m.Name, new { style = "font-size: 20px; height: 50px; width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 8px;" })
            </div>

            <div style="margin-bottom: 25px;">
                <label style="font-size: 20px; font-weight: bold; display: block; margin-bottom: 8px; color: #555;">Type</label>
                @Html.DropDownListFor(m => m.Type,
                    new SelectList(new[] { "String", "Integer", "Date", "Dropdown" }, Model.Type),
                    new { style = "font-size: 20px; height: 50px; width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 8px;", id = "propType", onchange = "checkDropdown()" })
            </div>

            <div style="margin-bottom: 25px;">
                <label style="font-size: 20px; font-weight: bold; color: #555;">
                    @Html.CheckBoxFor(m => m.IsRequired, new { style = "width: 20px; height: 20px; margin-right: 10px;" })
                    Required
                </label>
            </div>

            <div id="dropdownSection" style="margin-bottom: 25px; @(Model.Type == "Dropdown" ? "" : "display:none")">
                <label style="font-size: 20px; font-weight: bold; display: block; margin-bottom: 8px; color: #555;">Dropdown Options (comma separated)</label>
                @Html.TextBoxFor(m => m.DropdownOptions, new { style = "font-size: 20px; height: 50px; width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 8px;", placeholder = "e.g. Male,Female" })
            </div>

            <div style="margin-top: 30px;">
                <button type="submit" id="submitBtn" style="font-size: 20px; padding: 12px 30px; background: linear-gradient(135deg, #667eea, #764ba2); color: white; border: none; border-radius: 8px; cursor: pointer; margin-right: 10px;">
                    Save Changes
                </button>
                <a href="@Url.Action("Index", "PropertyDefinition")" style="font-size: 20px; padding: 12px 30px; background: #ccc; color: #333; border-radius: 8px; text-decoration: none;">
                    Back to List
                </a>
            </div>
        </form>
    </div>
</div>


<div id="successPopup" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%;
     background:rgba(0,0,0,0.5); z-index:9999; justify-content:center; align-items:center;">
    <div style="background:white; border-radius: 15px; padding: 40px; text-align:center; box-shadow: 0 5px 20px rgba(0,0,0,0.3);">
        <div style="font-size: 60px; color: #667eea;">✓</div>
        <h3 style="font-size: 24px; margin-top: 10px; color: #333;">Property updated successfully!</h3>
    </div>
</div>

<script>
    function checkDropdown() {
        var type = document.getElementById('propType').value;
        document.getElementById('dropdownSection').style.display =
            type === 'Dropdown' ? 'block' : 'none';
    }

    document.getElementById('submitBtn').addEventListener('click', function (e) {
        e.preventDefault();
        document.getElementById('successPopup').style.display = 'flex';
        setTimeout(function () {
            document.querySelector('form').submit();
        }, 1500);
    });
</script>