@model employees_mangment.Models.PropertyDefinition

@{
    ViewBag.Title = "Add Property";
}

<h2>Add New Property</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label>Property Name</label>
        @Html.TextBoxFor(m => m.Name, new { @class = "form-control" })
    </div>

    <div class="form-group">
        <label>Type</label>
        @Html.DropDownListFor(m => m.Type,
            new SelectList(new[] { "String", "Integer", "Date", "Dropdown" }),
            new { @class = "form-control", id = "propType", onchange = "checkDropdown()" })
    </div>

    <div class="form-group">
        <label>
            @Html.CheckBoxFor(m => m.IsRequired) Required
        </label>
    </div>

    <div class="form-group" id="dropdownSection" style="display:none">
        <label>Dropdown Options (comma separated)</label>
        @Html.TextBoxFor(m => m.DropdownOptions, new { @class = "form-control" })
    </div>

    <button type="submit" class="btn btn-success">Save Property</button>
    @Html.ActionLink("Back", "Index", null, new { @class = "btn btn-default" })
}

<script>
    function checkDropdown() {
        var type = document.getElementById('propType').value;
        document.getElementById('dropdownSection').style.display =
            type === 'Dropdown' ? 'block' : 'none';
    }
</script>