@model IEnumerable<employees_mangment.Models.PropertyDefinition>

@{
    ViewBag.Title = "Properties List";
}

<div style="padding: 30px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh;">
    <div style="background: white; border-radius: 15px; padding: 40px; width: 100%; box-shadow: 0 10px 30px rgba(0,0,0,0.2);">

        <h2 style="font-size: 28px; font-weight: bold; margin-bottom: 30px; color: #333; border-bottom: 3px solid #667eea; padding-bottom: 10px;">
            Properties List
        </h2>

        <table style="width: 100%; border-collapse: collapse; font-size: 18px;">
            <thead>
                <tr style="background: linear-gradient(135deg, #667eea, #764ba2); color: white;">
                    <th style="padding: 15px; text-align: left;">Name</th>
                    <th style="padding: 15px; text-align: left;">Type</th>
                    <th style="padding: 15px; text-align: left;">Required</th>
                    <th style="padding: 15px; text-align: left;">Options</th>
                    <th style="padding: 15px; text-align: left;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var prop in Model)
                {
                    <tr style="border-bottom: 1px solid #eee;">
                        <td style="padding: 15px;">@prop.Name</td>
                        <td style="padding: 15px;">@prop.Type</td>
                        <td style="padding: 15px;">@(prop.IsRequired ? " Yes" : " No")</td>
                        <td style="padding: 15px;">@prop.DropdownOptions</td>
                        <td style="padding: 15px;">
                            <a href="@Url.Action("Edit", "PropertyDefinition", new { id = prop.Id })"
                               style="background: #007bff; color: white; padding: 8px 15px; border-radius: 5px; text-decoration: none; font-size: 16px; margin-right: 5px;">
                                Edit
                            </a>
                            <a href="@Url.Action("Delete", "PropertyDefinition", new { id = prop.Id })"
                               style="background: #dc3545; color: white; padding: 8px 15px; border-radius: 5px; text-decoration: none; font-size: 16px;"
                               onclick="return confirm('Are you sure?')">
                                Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <br />
        <a href="@Url.Action("Create", "PropertyDefinition")" style="font-size: 20px; padding: 12px 25px; background: linear-gradient(135deg, #667eea, #764ba2); color: white; border-radius: 8px; text-decoration: none; display: inline-block; margin-top: 20px;">
             Add New Property
        </a>

    </div>
</div>