@model employees_mangment.Models.employees

@{
    ViewBag.Title = "Add Employee";
    var properties = ViewBag.Properties as List<employees_mangment.Models.PropertyDefinition>;
}

<div style="padding: 10px; background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">
    <div style="background: white; border-radius: 15px; padding: 10px; width: 100%; box-shadow: 0 10px 20px rgba(0,0,0,0.2);">

        <h2 style="font-size: 28px; font-weight: bold; margin-bottom: 30px; color: #333; border-bottom: 3px solid #11998e; padding-bottom: 10px;">
            Add New Employee
        </h2>

        <form id="employeeForm" action="/Employee/Create" method="post">
            @Html.AntiForgeryToken()

            <div style="margin-bottom: 25px;">
                <label style="font-size: 20px; font-weight: bold; display: block; margin-bottom: 8px; color: #555;">Employee Code *</label>
                @Html.TextBoxFor(m => m.Code, new { style = "font-size: 20px; height: 50px; width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 8px;", required = "required" })
            </div>

            <div style="margin-bottom: 25px;">
                <label style="font-size: 20px; font-weight: bold; display: block; margin-bottom: 8px; color: #555;">Employee Name *</label>
                @Html.TextBoxFor(m => m.Name, new { style = "font-size: 20px; height: 50px; width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 8px;", required = "required" })
            </div>

            <hr />
            <h4 style="font-size: 22px; font-weight: bold; margin-bottom: 20px; color: #333;">Custom Properties</h4>

            @if (properties != null)
            {
                for (int i = 0; i < properties.Count; i++)
                {
                    var prop = properties[i];
                    string fieldName = "prop_" + i;
                    string required = prop.IsRequired ? "required" : "";
                    <div style="margin-bottom: 25px;">
                        <label style="font-size: 20px; font-weight: bold; display: block; margin-bottom: 8px; color: #555;">
                            @prop.Name @(prop.IsRequired ? "*" : "")
                        </label>
                        @if (prop.Type == "Dropdown")
                        {
                            string[] opts = prop.DropdownOptions.Split(',');
                            <select name="@fieldName" style="font-size: 20px; height: 50px; width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 8px;">
                                @for (int j = 0; j < opts.Length; j++)
                                {
                                    <option value="@opts[j].Trim()">@opts[j].Trim()</option>
                                }
                            </select>
                        }
                        else if (prop.Type == "Date")
                        {
                            <input type="date" name="@fieldName" @required style="font-size: 20px; height: 50px; width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 8px;" />
                        }
                        else if (prop.Type == "Integer")
                        {
                            <input type="number" name="@fieldName" @required style="font-size: 20px; height: 50px; width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 8px;" />
                        }
                        else
                        {
                            <input type="text" name="@fieldName" @required style="font-size: 20px; height: 50px; width: 100%; padding: 10px; border: 2px solid #ddd; border-radius: 8px;" />
                        }
                    </div>
                }
            }

            <div style="margin-top: 30px;">
                <button type="submit" id="submitBtn" style="font-size: 20px; padding: 12px 30px; background: linear-gradient(135deg, #11998e, #38ef7d); color: white; border: none; border-radius: 8px; cursor: pointer; margin-right: 10px;">
                    Save Employee
                </button>
                <a href="@Url.Action("Index", "Employee")" style="font-size: 20px; padding: 12px 30px; background: #ccc; color: #333; border-radius: 8px; text-decoration: none;">
                    Back to List
                </a>
            </div>
        </form>
    </div>
</div>

<div id="successPopup" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%;
     background:rgba(0,0,0,0.5); z-index:9999; justify-content:center; align-items:center;">
    <div style="background:white; border-radius: 15px; padding: 20px; text-align:center; box-shadow: 0 5px 20px rgba(0,0,0,0.3);">
        <div style="font-size: 60px; color: #11998e;">✓</div>
        <h3 style="font-size: 24px; margin-top: 10px; color: #333;">Employee added successfully!</h3>
    </div>
</div>

<script>
    document.getElementById('submitBtn').addEventListener('click', function (e) {
        e.preventDefault();
        var form = document.getElementById('employeeForm');
        var inputs = form.querySelectorAll('[required]');
        var valid = true;

        inputs.forEach(function (input) {
            if (!input.value) {
                input.style.border = '2px solid red';
                input.style.backgroundColor = '#fff0f0';
                valid = false;
            } else {
                input.style.border = '2px solid #ddd';
                input.style.backgroundColor = 'white';
            }
        });

        if (valid) {
            document.getElementById('successPopup').style.display = 'flex';
            setTimeout(function () {
                form.submit();
            }, 1500);
        }
    });
</script>